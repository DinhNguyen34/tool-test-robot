<UserControl x:Class="ModuleMotor.Views.MotorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">

    <UserControl.Resources>

        <!-- Button styles -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Padding"          Value="10,0"/>
        </Style>
        <Style x:Key="PrimaryBtn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#339AF0"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#555"/>
        </Style>
        <Style x:Key="SuccessBtn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#40C057"/>
        </Style>
        <Style x:Key="WarningBtn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#F59F00"/>
        </Style>
        <Style x:Key="DangerBtn"    TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#FA5252"/>
        </Style>
        <Style x:Key="TestCaseBtn" TargetType="Button">
            <Setter Property="Foreground"            Value="White"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="FontSize"              Value="12"/>
            <Setter Property="FontWeight"            Value="SemiBold"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Height"                Value="50"/>
            <Setter Property="Width"                 Value="150"/>
            <Setter Property="Margin"                Value="6"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="3"
                                                  Direction="270" Opacity="0.30"
                                                  Color="WhiteSmoke"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- ① Loaded: bounce in from scale 0 → 1 -->
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            From="0.0" To="1.0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="7"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            From="0.0" To="1.0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="7"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            From="0.0" To="1.0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ② Hover (MouseEnter): zoom up + deep shadow → emerging effect -->
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.07"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.07"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="22"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="12"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.65"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ③ MouseLeave: restore to resting state -->
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.0"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.0"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="8"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="3"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.30"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ④ Pressed: scale down + weak shadow → pressed-down effect -->
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="0.94"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="0.94"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="2"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="1"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ⑤ Released: spring back to hover state -->
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.07">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.07">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="22"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="12"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.65"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.40"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"              Value="#2A2A2A"/>
            <Setter Property="Foreground"              Value="White"/>
            <Setter Property="BorderBrush"             Value="#555"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="4,3"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <LinearGradientBrush x:Key="ConfigAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF9C3A" Offset="0"/>
            <GradientStop Color="#FF4FA8" Offset="0.45"/>
            <GradientStop Color="#B04DFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ConfigPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1D2434" Offset="0"/>
            <GradientStop Color="#171D2C" Offset="0.55"/>
            <GradientStop Color="#131928" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ConfigRowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1C2334" Offset="0"/>
            <GradientStop Color="#151B28" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ConfigRowCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConfigRowBrush}"/>
            <Setter Property="BorderBrush" Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ConfigLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6DEFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ConfigFieldTextBox" TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Background" Value="#0F1421"/>
            <Setter Property="Foreground" Value="#F4F7FF"/>
            <Setter Property="BorderBrush" Value="#56627F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CaretBrush" Value="#F4F7FF"/>
        </Style>

        <Style x:Key="ConfigFieldComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#0F1421"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#56627F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0F1421"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3E2B61"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigIconButton" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#27314A"/>
            <Setter Property="BorderBrush" Value="#5D6A8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <TextBlock Text="⟳" FontSize="22" Height="33"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="Light"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#AAAAAA"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>

        <!-- Col label -->
        <Style x:Key="ColLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#888"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header bar -->
            <RowDefinition Height="*"/>
            <!-- main content -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR ════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526" Padding="10,7">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resource;component/Images/Robot-32.png"
                           Height="22" Width="22" Margin="70,0,8,0"/>
                    <TextBlock Text="Motor Control" FontSize="18" FontWeight="Bold"
                               Foreground="#339AF0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <ComboBox Grid.Column="1"
                       ItemsSource="{Binding Model.ListcanDevices}"
                       SelectedItem="{Binding Model.SelectedCan}"  DisplayMemberPath="DisplayName"
                       Style="{StaticResource ConfigFieldComboBox}" Width="150">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="DropDownOpened">
                                <i:InvokeCommandAction Command="{Binding OpenListCan}" CommandParameter="CAN"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>
                    <Button Command="{Binding CanConnectCommand}" Width="110" Margin="0,0,6,0">
                        
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SuccessBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#FA5252"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{Binding ConnectLabel}" TextAlignment="Center"/>
                    </Button>

                    <!--Button Content="Hold Pos"   Command="{Binding HoldPositionCommand}"
                            Style="{StaticResource WarningBtn}" Width="80"  Margin="0,0,6,0"-->
                    <!--Button Content="Zero CMD"   Command="{Binding ZeroCmdCommand}"
                            Style="{StaticResource SecondaryBtn}" Width="80" Margin="0,0,6,0"-->
                    <!--Button Content="Save Log"   Command="{Binding SaveLogCommand}"
                            Style="{StaticResource PrimaryBtn}"   Width="80" Margin="0,0,6,0"-->
                    <Button Content= "{Binding SaveLogButtonText}" Command="{Binding SaveLogCommand}"
                            Width="80" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveLogButtonText}" Value="Stop Log">
                                        <Setter Property="Background" Value="#FA5252"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Load Config" Command="{Binding LoadConfigCommand}"
                            Style="{StaticResource SecondaryBtn}" Width="90" Margin="0,0,6,0"/>
                    <Button Content="Save Config" Command="{Binding SaveConfigCommand}"
                            Style="{StaticResource SecondaryBtn}" Width="90" Margin="0,0,16,0"/>

                    <!-- Status -->
                    <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,156,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="DISCONNECTED"/>
                                <Setter Property="Foreground" Value="#FA5252"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text"       Value="CONNECTED"/>
                                        <Setter Property="Foreground" Value="#69DB7C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>


                </StackPanel>
                <Button Content="← Back" Style="{StaticResource SecondaryBtn}"
                        Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left" Width="67"/>
            </Grid>

        </Border>

        <!-- ═══ MAIN CONTENT (two columns) ════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500"/>
                <!-- LEFT: test cases + motor control -->
                <ColumnDefinition Width="*"/>
                <!-- RIGHT: state table + config + log -->
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT COLUMN ─────────────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- test cases -->
                    <RowDefinition Height="*"/>
                    <!-- motor control -->
                </Grid.RowDefinitions>

                <!-- Test Cases -->
                <Border Grid.Row="0"
                        BorderBrush="#3A425C"
                        BorderThickness="1"
                        CornerRadius="12"
                        Background="{StaticResource ConfigPanelBrush}" Margin="4,4,2,2" Padding="10,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.18"
                                          Color="#000000">

                        </DropShadowEffect>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource ConfigAccentBrush}"
                                CornerRadius="12,12,2,2">
                            <Grid Margin=" 0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="TESTCASE"
                                           Margin="12,0,0,-6"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#FFF1D8"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="14,12,14,12">
                            <UniformGrid Rows="4" Columns="2">
                                <Button Content="Get Device ID" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[0].Command}"
                                    Background="#1F6FEB" BorderBrush="#0D3B66"/>
                                <Button Content="Motor Enabled" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[1].Command}"
                                    Background="#2EA043" BorderBrush="#1B7F37"/>
                                <Button Content="Motor Stop" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[2].Command}"
                                    Background="#BF8700" BorderBrush="#9A6700"/>
                                <Button Content="Set Zero Mechanical" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[3].Command}"
                                    Background="#1F6FEB" BorderBrush="#0D3B66"/>
                                <Button Content="Max Position" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[4].Command}"
                                    Background="#2EA043" BorderBrush="#1B7F37"/>
                                <Button Content="Min Position" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[5].Command}"
                                    Background="#BF8700" BorderBrush="#9A6700"/>
                                <Button Content="Get State Motor" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[6].Command}"
                                    Background="#2EA043" BorderBrush="#1B7F37"/>
                                <Button Content="Max Speed" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[7].Command}"
                                    Background="#BF8700" BorderBrush="#9A6700"/>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>


                <!-- Motor Control -->
                <Border Grid.Row="1" Margin="4,4,2,4" Padding="10,8" Style="{StaticResource ConfigRowCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- title + bulk kp/kd -->
                            <RowDefinition Height="Auto"/>
                            <!-- column headers -->
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <!-- motor rows -->
                        </Grid.RowDefinitions>

                        <!-- Title + bulk Kp/Kd -->
                        <Border Grid.Row="0" Style="{StaticResource ConfigRowCard}">
                            <Grid>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="MOTOR CONTROL" Style="{StaticResource ConfigLabel}" Foreground="#FFD43B"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1"
                                Style="{StaticResource ConfigRowCard}">

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="All Kp:" Style="{StaticResource ColLabel}" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding AllKp, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ConfigFieldTextBox}" Width="60"/>
                                <Button Content="Set" Command="{Binding SetAllKpCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Height="26" Width="36" FontSize="11" Margin="4,0,16,0"/>

                                <TextBlock Text="All Kd:" Style="{StaticResource ColLabel}" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding AllKd, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ConfigFieldTextBox}" Width="60" TextChanged="TextBox_TextChanged"/>
                                <Button Content="Set" Command="{Binding SetAllKdCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Height="26" Width="36" FontSize="11" Margin="4,0,16,0"/>

                                <!--Button Content="Send" Command="{Binding SendMotorCommand}"
                                        Style="{StaticResource SuccessBtn}"
                                        Height="26" Width="52" FontSize="11" Margin="0,0,6,0"-->
                                <Button Content="Send All" Command="{Binding SendAllMotorsCommand}"
                                        Style="{StaticResource SuccessBtn}"
                                        Height="26" Width="68" FontSize="11" Margin="54,0,12,0"/>
                            </StackPanel>


                        </Border>

                        <!-- Column headers -->
                        <Border Grid.Row="2" BorderBrush="#444" BorderThickness="0,0,0,0" Padding="0,0,0,4" Margin="0,0,0,5" RenderTransformOrigin="0.5,0.5" Grid.RowSpan="2">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleY="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Grid Margin="0,19,0,-17" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleY="-1"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0*"/>
                                    <RowDefinition Height="14.63"/>
                                    <RowDefinition Height="0*"/>
                                    <RowDefinition Height="0*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <!-- checkbox -->
                                    <ColumnDefinition Width="36"/>
                                    <!-- ID -->
                                    <ColumnDefinition Width="72"/>
                                    <!-- q_cmd -->
                                    <ColumnDefinition Width="72"/>
                                    <!-- dq -->
                                    <ColumnDefinition Width="60"/>
                                    <!-- tau -->
                                    <ColumnDefinition Width="58"/>
                                    <!-- Kp -->
                                    <ColumnDefinition Width="58"/>
                                    <!-- Kd -->
                                    <ColumnDefinition Width="52"/>
                                    <!-- Send -->
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="En" FontSize="14"   Style="{StaticResource ColLabel}" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,-19,23,0" Grid.RowSpan="2" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="ID" FontSize="14"   Style="{StaticResource ColLabel}" Grid.Row="1" Grid.ColumnSpan="2" Margin="-9,-19,70,0" Grid.RowSpan="3" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2" Text="q_cmd" FontSize="14" Style="{StaticResource ColLabel}" Grid.Row="1" Grid.ColumnSpan="2" Margin="-15,-19,55,0" Grid.RowSpan="3" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="3" Text="dq" FontSize="14"   Style="{StaticResource ColLabel}" Grid.Row="1" Grid.ColumnSpan="2" Margin="-12,-19,50,0" Grid.RowSpan="2" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="4" Text="tau" FontSize="14"  Style="{StaticResource ColLabel}" Grid.Row="1" Grid.ColumnSpan="2" Margin="-12,-19,40,0" Grid.RowSpan="3" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="5" Text="Kp" FontSize="14"   Style="{StaticResource ColLabel}" Grid.Row="1" Grid.ColumnSpan="2" Margin="-12,-19,40,0" Grid.RowSpan="3" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="6" Text="Kd" FontSize="14"   Style="{StaticResource ColLabel}" Grid.Row="1" Margin="-12,-19,-15,0" Grid.RowSpan="3" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="7" Text="Send" FontSize="14" Style="{StaticResource ColLabel}" Grid.Row="1" Margin="-12,-19,-15,0" Grid.RowSpan="3" VerticalAlignment="Top"/>
                            </Grid>
                        </Border>

                        <!-- Motor rows -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Motors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="52"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       Foreground="#74C0FC" FontSize="12"
                                                       VerticalAlignment="Center" Margin="2,0"/>
                                            <TextBox Grid.Column="2"
                                                     Text="{Binding QCmd, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ConfigFieldTextBox}" Margin="1,0"/>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding DqCmd, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ConfigFieldTextBox}" Margin="1,0"/>
                                            <TextBox Grid.Column="4"
                                                     Text="{Binding TauCmd, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ConfigFieldTextBox}" Margin="1,0"/>
                                            <TextBox Grid.Column="5"
                                                     Text="{Binding Kp, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ConfigFieldTextBox}" Margin="1,0"/>
                                            <TextBox Grid.Column="6"
                                                     Text="{Binding Kd, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ConfigFieldTextBox}" Margin="1,0"/>
                                            <Button Grid.Column="7" Content="Send"
                                                    Command="{Binding DataContext.SendMotorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SuccessBtn}"
                                                    Height="22" FontSize="10" Margin="2,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </Grid>
                </Border>
            </Grid>

            <!-- ─── RIGHT COLUMN ─────────────────────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- state table -->
                    <RowDefinition Height="Auto"/>
                    <!-- config -->
                    <RowDefinition Height="*"/>
                    <!-- log -->
                </Grid.RowDefinitions>

                <!-- Motor State Table -->
                <!--Border Grid.Row="0" Margin="2,4,4,2" Padding="10,8" Style="{StaticResource ConfigRowCard}">
                    <StackPanel>
                        <TextBlock Text="MOTOR STATE" Style="{StaticResource SectionHeader}"
                                   Foreground="#74C0FC"/>
                        <DataGrid ItemsSource="{Binding Motors}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowBackground="#1E1E1E"
                                  AlternatingRowBackground="#222"
                                  Foreground="White"
                                  Background="#1E1E1E"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#333"
                                  FontFamily="Consolas" FontSize="12"
                                  MaxHeight="260">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"       Value="#2D2D2D"/>
                                    <Setter Property="Foreground"       Value="#AAAAAA"/>
                                    <Setter Property="Padding"          Value="6,3"/>
                                    <Setter Property="BorderBrush"      Value="#444"/>
                                    <Setter Property="BorderThickness"  Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="6,2"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"       Binding="{Binding Label}"                        Width="40"/>
                                <DataGridTextColumn Header="q (rad)"  Binding="{Binding Q,   StringFormat={}{0:+0.0000;-0.0000}}" Width="90"/>
                                <DataGridTextColumn Header="dq (r/s)" Binding="{Binding Dq,  StringFormat={}{0:+0.0000;-0.0000}}" Width="90"/>
                                <DataGridTextColumn Header="tau (Nm)" Binding="{Binding Tau, StringFormat={}{0:+0.0000;-0.0000}}" Width="90"/>
                                <DataGridTextColumn Header="Temp °C"  Binding="{Binding Temperature, StringFormat={}{0:F1}}"      Width="70"/>
                                <DataGridTemplateColumn Header="Error" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ErrorText}" Padding="6,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#69DB7C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                <Border-->

                <!-- Config Panel -->
                <Border Grid.Row="1"
                        Margin="2,2,4,2"
                        CornerRadius="12"
                        BorderBrush="#3A425C"
                        BorderThickness="1"
                        Background="{StaticResource ConfigPanelBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.18" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Background="{StaticResource ConfigAccentBrush}"
                                CornerRadius="12,12,0,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="CONFIG"
                                           Margin="12,6,12,0"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#FFF1D8"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Motor communication setup"                                        
                                           Foreground="WhiteSmoke"
                                           FontSize="11"
                                           Margin="14,6,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="14,12,14,12">

                            <!-- Row 1: Port device + baud rate -->
                            <Border Style="{StaticResource ConfigRowCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="COM Port"
                                               Style="{StaticResource ConfigLabel}"
                                               Width="72"
                                               Margin="0,7,10,0"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailablePorts}"
                                              SelectedItem="{Binding SelectedPort}"
                                              Style="{StaticResource ConfigFieldComboBox}"/>
                                    <Button Grid.Column="3" Content="⟳"
                                        Command="{Binding RefreshPortsCommand}"
                                        ToolTip="Refresh COM ports"
                                        Style="{StaticResource ConfigIconButton}"
                                        Margin="8,0,0,0"/>

                                    <TextBlock Grid.Column="4"
                                               Text="Baud Rate"
                                               Style="{StaticResource ConfigLabel}"
                                               Width="78"
                                               Margin="12,7,10,0"/>
                                    <ComboBox Grid.Column="5"
                                              ItemsSource="{Binding BaudRates}"
                                              SelectedItem="{Binding SelectedBaud}"
                                              Style="{StaticResource ConfigFieldComboBox}"/>
                                    <TextBlock Grid.Column="6"
                                               Text="Refresh"
                                               Style="{StaticResource ConfigLabel}"
                                               Width="60"
                                               Margin="12,7,8,0"/>
                                    <TextBox Grid.Column="7"
                                             Text="{Binding Config.RefreshHz, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ConfigFieldTextBox}"/>
                                    <TextBlock Grid.Column="8"
                                               Text="ms"
                                               Foreground="#AAB5D8"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ConfigRowCard}" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.35*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="Motor ID" Style="{StaticResource ConfigLabel}"/>
                                        <TextBox Text="{Binding Config.MotorId, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ConfigFieldTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                        <TextBlock Text="Net Port" Style="{StaticResource ConfigLabel}"/>
                                        <TextBox Text="{Binding Config.Port, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ConfigFieldTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Log File" Style="{StaticResource ConfigLabel}"/>
                                        <TextBox Text="{Binding Config.LogFile, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ConfigFieldTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="{Binding LogStatusText}"
                                       FontSize="11"
                                       Foreground="#98A6CA"
                                       Margin="2,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Log Panel -->
                <Border Grid.Row="2" Margin="2,2,4,4" Padding="10,8" Style="{StaticResource ConfigRowCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="LOG" Style="{StaticResource ConfigLabel}"
                                       FontSize="17"
                                       Foreground="#69DB7C" VerticalAlignment="Center"/>
                            <Button Content="Clear" Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource ConfigIconButton}"
                                    Height="20" Width="44" FontSize="11" Margin="10,-5,9,0"/>
                        </StackPanel>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding LogEntries}"
                                 Background="Black"
                                 Foreground="#CCCCCC"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" d:ItemsSource="{d:SampleData ItemCount=5}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"          Value="8,2"/>
                                    <Setter Property="BorderThickness"  Value="0"/>
                                    <Setter Property="Background"       Value="Transparent"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
