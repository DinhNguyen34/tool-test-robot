                                  MaxHeight="260">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"       Value="#2D2D2D"/>
                                    <Setter Property="Foreground"       Value="#AAAAAA"/>
                                    <Setter Property="Padding"          Value="6,3"/>
                                    <Setter Property="BorderBrush"      Value="#444"/>
                                    <Setter Property="BorderThickness"  Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="6,2"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"       Binding="{Binding Label}"                        Width="40"/>
                                <DataGridTextColumn Header="q (rad)"  Binding="{Binding Q,   StringFormat={}{0:+0.0000;-0.0000}}" Width="90"/>
                                <DataGridTextColumn Header="dq (r/s)" Binding="{Binding Dq,  StringFormat={}{0:+0.0000;-0.0000}}" Width="90"/>
                                <DataGridTextColumn Header="tau (Nm)" Binding="{Binding Tau, StringFormat={}{0:+0.0000;-0.0000}}" Width="90"/>
                                <DataGridTextColumn Header="Temp °C"  Binding="{Binding Temperature, StringFormat={}{0:F1}}"      Width="70"/>
                                <DataGridTemplateColumn Header="Error" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ErrorText}" Padding="6,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#69DB7C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                <Border-->

                <!-- Config Panel -->
                <Border Grid.Row="1"
                        Margin="2,2,4,2"
                        CornerRadius="12"
                        BorderBrush="#3A425C"
                        BorderThickness="1"
                        Background="{StaticResource ConfigPanelBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.18" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Background="{StaticResource ConfigAccentBrush}"
                                CornerRadius="12,12,0,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="CONFIG"
                                           Margin="12,6,12,0"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#FFF1D8"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Motor communication setup"                                        
                                           Foreground="WhiteSmoke"
                                           FontSize="11"
                                           Margin="14,6,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="14,12,14,12">

                            <!-- Row 1: Port device + baud rate -->
                            <!--Border Style="{StaticResource ConfigRowCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="COM Port"
                                               Style="{StaticResource ConfigLabel}"
                                               Width="72"
                                               Margin="0,7,10,0"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailablePorts}"
                                              SelectedItem="{Binding SelectedPort}"
                                              Style="{StaticResource ConfigFieldComboBox}"/>
                                    <Button Grid.Column="3" Content="⟳"
                                        Command="{Binding RefreshPortsCommand}"
                                        ToolTip="Refresh COM ports"
                                        Style="{StaticResource ConfigIconButton}"
                                        Margin="8,0,0,0"/>

                                    <TextBlock Grid.Column="4"
                                               Text="Baud Rate"
                                               Style="{StaticResource ConfigLabel}"
                                               Width="78"
                                               Margin="12,7,10,0"/>
                                    <ComboBox Grid.Column="5"
                                              ItemsSource="{Binding BaudRates}"
                                              SelectedItem="{Binding SelectedBaud}"
                                              Style="{StaticResource ConfigFieldComboBox}"/>
                                    <TextBlock Grid.Column="6"
                                               Text="Refresh"
                                               Style="{StaticResource ConfigLabel}"
                                               Width="60"
                                               Margin="12,7,8,0"/>
                                    <TextBox Grid.Column="7"
                                             Text="{Binding Config.RefreshHz, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ConfigFieldTextBox}"/>
                                    <TextBlock Grid.Column="8"
                                               Text="ms"
                                               Foreground="#AAB5D8"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border-->

                            <Border Style="{StaticResource ConfigRowCard}" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.35*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="Protocol" Style="{StaticResource ConfigLabel}"/>
                                        <ComboBox ItemsSource="{Binding SupportedProtocols}"
                                                  SelectedItem="{Binding SelectedProtocol}"
                                                  Style="{StaticResource ConfigFieldComboBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                        <TextBlock Text="Motor ID" Style="{StaticResource ConfigLabel}"/>
                                        <TextBox Text="{Binding Config.MotorId, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ConfigFieldTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                                        <TextBlock Text="Net Port" Style="{StaticResource ConfigLabel}"/>
                                        <TextBox Text="{Binding Config.Port, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ConfigFieldTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Log File" Style="{StaticResource ConfigLabel}"/>
                                        <TextBox Text="{Binding Config.LogFile, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ConfigFieldTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="{Binding LogStatusText}"
                                       FontSize="11"
                                       Foreground="#98A6CA"
                                       Margin="2,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RX Live + LOG tabs -->
                <TabControl Grid.Row="2" Margin="2,2,4,4"
                            Background="#161B27"
                            BorderBrush="#3A425C">

                    <!-- ── RX Live ── -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="RX Live">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- toolbar -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                                <TextBlock Text="RX LIVE"
                                           Style="{StaticResource ConfigLabel}"
                                           FontSize="14" Foreground="#74C0FC"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding RxStatusText}"
                                           FontSize="11" Foreground="#98A6CA"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button Content="Clear"
                                        Command="{Binding ClearRxCommand}"
                                        Style="{StaticResource ConfigIconButton}"
                                        Height="20" Width="44" FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- frame table -->
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding RxFrames}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      RowBackground="#1A1F2E"
                                      AlternatingRowBackground="#1E2435"
                                      Foreground="#D4D4D4"
                                      Background="#161B27"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#2A2F40"
                                      FontFamily="Consolas"
                                      FontSize="12">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"      Value="#1E2435"/>
                                        <Setter Property="Foreground"      Value="#8899BB"/>
                                        <Setter Property="Padding"         Value="6,3"/>
                                        <Setter Property="BorderBrush"     Value="#3A425C"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding"         Value="6,2"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time"   Binding="{Binding TimeText}"   Width="90"/>
                                    <DataGridTextColumn Header="CH"     Binding="{Binding Channel}"    Width="38"/>
                                    <DataGridTemplateColumn Header="Status" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusText}" Padding="4,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#69DB7C"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="0">
                                                                    <Setter Property="Foreground" Value="#69DB7C"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="1">
                                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Data (hex)" Binding="{Binding DataHex}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ── LOG ── -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="LOG">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                                <TextBlock Text="LOG"
                                           Style="{StaticResource ConfigLabel}"
                                           FontSize="14" Foreground="#69DB7C"
                                           VerticalAlignment="Center"/>
                                <Button Content="Clear" Command="{Binding ClearLogCommand}"
                                        Style="{StaticResource ConfigIconButton}"
                                        Height="20" Width="44" FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding LogEntries}"
                                     Background="Black"
                                     Foreground="#CCCCCC"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"         Value="8,2"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background"      Value="Transparent"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </TabItem>

                </TabControl>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
