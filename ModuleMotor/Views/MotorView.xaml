<UserControl x:Class="ModuleMotor.Views.MotorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Button styles -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Padding"          Value="10,0"/>
        </Style>
        <Style x:Key="PrimaryBtn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#339AF0"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#555"/>
        </Style>
        <Style x:Key="SuccessBtn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#40C057"/>
        </Style>
        <Style x:Key="WarningBtn"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#F59F00"/>
        </Style>
        <Style x:Key="DangerBtn"    TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#FA5252"/>
        </Style>
        <Style x:Key="TestCaseBtn" TargetType="Button">
            <Setter Property="Foreground"            Value="White"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="FontSize"              Value="12"/>
            <Setter Property="FontWeight"            Value="SemiBold"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Height"                Value="50"/>
            <Setter Property="Width"                 Value="150"/>
            <Setter Property="Margin"                Value="6"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="3"
                                                  Direction="270" Opacity="0.30"
                                                  Color="WhiteSmoke"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- ① Loaded: bounce in from scale 0 → 1 -->
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            From="0.0" To="1.0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="7"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            From="0.0" To="1.0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="7"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            From="0.0" To="1.0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ② Hover (MouseEnter): zoom up + deep shadow → emerging effect -->
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.07"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.07"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="22"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="12"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.65"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ③ MouseLeave: restore to resting state -->
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.0"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.0"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="8"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="3"/>
                                        <DoubleAnimation Duration="0:0:0.18"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.30"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ④ Pressed: scale down + weak shadow → pressed-down effect -->
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="0.94"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="0.94"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="2"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="1"/>
                                        <DoubleAnimation Duration="0:0:0.07"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!-- ⑤ Released: spring back to hover state -->
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.07">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.07">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                            To="22"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                            To="12"/>
                                        <DoubleAnimation Duration="0:0:0.15"
                                            Storyboard.TargetName="bd"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.65"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.40"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"              Value="#2A2A2A"/>
            <Setter Property="Foreground"              Value="White"/>
            <Setter Property="BorderBrush"             Value="#555"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="4,3"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <LinearGradientBrush x:Key="ConfigAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF9C3A" Offset="0"/>
            <GradientStop Color="#FF4FA8" Offset="0.45"/>
            <GradientStop Color="#B04DFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ConfigPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1D2434" Offset="0"/>
            <GradientStop Color="#171D2C" Offset="0.55"/>
            <GradientStop Color="#131928" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ConfigRowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1C2334" Offset="0"/>
            <GradientStop Color="#151B28" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ConfigRowCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConfigRowBrush}"/>
            <Setter Property="BorderBrush" Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ConfigLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6DEFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ConfigFieldTextBox" TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Background" Value="#0F1421"/>
            <Setter Property="Foreground" Value="#F4F7FF"/>
            <Setter Property="BorderBrush" Value="#56627F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CaretBrush" Value="#F4F7FF"/>
        </Style>

        <Style x:Key="ConfigFieldComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#243047"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0F1421"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3E2B61"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Background" Value="#243047"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#4B638C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                                <ToggleButton Grid.ColumnSpan="2"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup Grid.ColumnSpan="2"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BuilderModeComboBox"
       TargetType="ComboBox"
       BasedOn="{StaticResource ConfigFieldComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1B2230"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Padding" Value="4,0"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Background" Value="#2B3A55"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#4B638C"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False">
                    <Setter Property="Background" Value="#1B2230"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#333333"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="ConfigIconButton" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#27314A"/>
            <Setter Property="BorderBrush" Value="#5D6A8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <TextBlock Text="⟳" FontSize="22" Height="33"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="Light"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#AAAAAA"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>

        <!-- Col label -->
        <Style x:Key="ColLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#888"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header bar -->
            <RowDefinition Height="*"/>
            <!-- main content -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR ════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526" Padding="10,7">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resource;component/Images/Robot-32.png"
                           Height="22" Width="22" Margin="70,0,8,0"/>
                    <TextBlock Text="Motor Control" FontSize="18" FontWeight="Bold"
                               Foreground="#339AF0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <ComboBox Grid.Column="1"
                       ItemsSource="{Binding Model.ListcanDevices}"
                       SelectedItem="{Binding Model.SelectedCan, Mode=TwoWay}"  
                       Style="{StaticResource ConfigFieldComboBox}" Width="150">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="DropDownOpened">
                                <i:InvokeCommandAction Command="{Binding OpenListCan}" CommandParameter="CAN"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>
                    <TextBlock Text="CAN"
                               Margin="10,0,6,0"
                               VerticalAlignment="Center"
                               Foreground="#D6DEFF"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <!--ComboBox ItemsSource="{Binding CanBitratesKbps}"
                              SelectedItem="{Binding SelectedCanBitrate}"
                              Style="{StaticResource ConfigFieldComboBox}"
                              Width="92"
                              Margin="0,0,4,0"/-->
                    <!--TextBlock Text="kbps"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#9AA6C8"
                               FontSize="11"/-->
                    <Button Command="{Binding CanConnectCommand}" Width="120" Margin="0,0,6,0">

                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SuccessBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#FA5252"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{Binding ConnectLabel}" TextAlignment="Center"/>
                    </Button>

                    <!--Button Content="Hold Pos"   Command="{Binding HoldPositionCommand}"
                            Style="{StaticResource WarningBtn}" Width="80"  Margin="0,0,6,0"-->
                    <!--Button Content="Zero CMD"   Command="{Binding ZeroCmdCommand}"
                            Style="{StaticResource SecondaryBtn}" Width="80" Margin="0,0,6,0"-->
                    <!--Button Content="Save Log"   Command="{Binding SaveLogCommand}"
                            Style="{StaticResource PrimaryBtn}"   Width="80" Margin="0,0,6,0"-->
                    <Button Content= "{Binding SaveLogButtonText}" Command="{Binding SaveLogCommand}"
                            Width="80" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveLogButtonText}" Value="Stop Log">
                                        <Setter Property="Background" Value="#FA5252"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Load Config" Command="{Binding LoadConfigCommand}"
                            Style="{StaticResource SecondaryBtn}" Width="90" Margin="0,0,6,0"/>
                    <Button Content="Save Config" Command="{Binding SaveConfigCommand}"
                            Style="{StaticResource SecondaryBtn}" Width="90" Margin="0,0,150,0"/>

                    <!-- Status -->
                    <!--TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,84,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="DISCONNECTED"/>
                                <Setter Property="Foreground" Value="#FA5252"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text"       Value="CONNECTED"/>
                                        <Setter Property="Foreground" Value="#69DB7C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock-->


                </StackPanel>
                <Button Content="← Back" Style="{StaticResource SecondaryBtn}"
                        Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left" Width="67"/>
            </Grid>

        </Border>

        <!-- ═══ MAIN CONTENT (two columns) ════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500"/>
                <!-- LEFT: test cases + motor control -->
                <ColumnDefinition Width="*"/>
                <!-- RIGHT: state table + config + log -->
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT COLUMN ─────────────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- test cases -->
                    <RowDefinition Height="*"/>
                    <!-- motor control -->
                </Grid.RowDefinitions>

                <!-- Test Cases -->
                <Border Grid.Row="0"
                        BorderBrush="#3A425C"
                        BorderThickness="1"
                        CornerRadius="12"
                        Background="{StaticResource ConfigPanelBrush}" Margin="4,4,2,2" Padding="10,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.18"
                                          Color="#000000">

                        </DropShadowEffect>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource ConfigAccentBrush}"
                                CornerRadius="12,12,2,2">
                            <Grid Margin=" 0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="QUICK LIBRARY"
                                           Margin="12,0,0,-6"
                                           Style="{StaticResource SectionHeader}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#FFF1D8"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="14,12,14,12">

                            <!--ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Background="#1E2433"
                                            BorderBrush="#37415A"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize ="11"
                                                       Foreground="#9AA6C8"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate-->

                            <UniformGrid Rows="4" Columns="2">
                                <Button Content="{Binding TestCases[0].Label}" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[0].Command}"
                                    Background="DodgerBlue" BorderBrush="DodgerBlue"/>
                                <Button Content="{Binding TestCases[1].Label}" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[1].Command}"
                                    Background="DodgerBlue" BorderBrush="#0D3B66"/>
                                <Button Content="{Binding TestCases[2].Label}" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[2].Command}"
                                    Background="IndianRed" BorderBrush="PaleVioletRed"/>
                                <Button Content="{Binding TestCases[3].Label}" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[3].Command}"
                                    Background="DodgerBlue" BorderBrush="#0D3B66"/>
                                <Button Content="{Binding TestCases[4].Label}" Style="{StaticResource TestCaseBtn}"
                                    Command="{Binding TestCases[4].Command}"
