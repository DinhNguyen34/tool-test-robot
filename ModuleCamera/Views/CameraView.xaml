<UserControl x:Class="ModuleCamera.Views.CameraView"
             xmlns:prism="http://prismlibrary.com/"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:ModuleCamera"
             xmlns:helix="http://helix-toolkit.org/wpf"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1280"
             Background="Black">

    <UserControl.Resources>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SegmentedButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#007ACC"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#1E2129" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <Button Content="← Back" Command="{Binding BackCommand}" Width="85" Height="32" Background="#3E3E42" Foreground="White"/>
                <Image Source="/Resource;component/Images/Robot-32.png" Width="24" Height="24" Margin="15,0,10,0"/>
                <TextBlock Text="Camera Control" Foreground="#46A3FF" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="Mode:" Foreground="#46A3FF" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="100,0,10,0"/>
                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4" ClipToBounds="True" Background="#4E4E4E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="btn2D" Grid.Column="0" Content="2D" Foreground="White"
                         GroupName="ViewMode" Width="50" Height="40" Style="{StaticResource SegmentedButtonStyle}"
                         IsChecked="{Binding Is3DMode, Converter={StaticResource InverseBooleanConverter}}"/>

                        <Rectangle Grid.Column="1" Fill="#555" Width="1" Margin="0,5"/>

                        <RadioButton x:Name="btn3D" Grid.Column="2" Content="3D" Foreground="White"
                         GroupName="ViewMode" Width="50" Height="40" Style="{StaticResource SegmentedButtonStyle}"
                         IsChecked="{Binding Is3DMode}"/>
                    </Grid>
                </Border>
            </StackPanel> 

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <ToggleButton x:Name="btnCameraPower" IsChecked="{Binding IsCameraOn, Mode=TwoWay}" Command="{Binding ConnectCommand}" Width="70" Height="30" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand">
                </ToggleButton>
                <Border Background="#2D2D30" CornerRadius="3" Margin="15,0,5,0" Padding="12,5">
                    <TextBlock Text="{Binding ConnectionStatus, FallbackValue='DISCONNECTED'}" 
                   Foreground="{Binding StatusColor, FallbackValue='#FF4B4B'}" 
                   FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                </Border>
            </StackPanel> 
        </Grid>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E2129" CornerRadius="5" Margin="5">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="35" CornerRadius="5,5,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FF8E2D" Offset="0"/>
                                <GradientStop Color="#FF4BA4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="SETTINGS" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                    </Border> 
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#474F5A">
                        <StackPanel Margin="10">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Select Device:" Foreground="#46A3FF" FontWeight="Bold" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox Width="150" Height="25" Background="White" 
                                              ItemsSource="{Binding CameraSettings.AvailableDevices}"
                                              SelectedValuePath="Serial"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding CameraSettings.SelectedDeviceSerial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalContentAlignment="Left" VerticalContentAlignment="Center" />
                                    <Button Command="{Binding RefreshDevicesCommand}" Width="25" Height="25" Margin="5,0,0,0" ToolTip="Refresh Device List" Background="#3E3E42" BorderThickness="0">
                                        <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Preset:" Foreground="#B0BCC7" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" Width="120" Height="25" SelectedValuePath="Content" SelectedItem="{Binding CameraSettings.SelectedPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" >
                                    <ComboBoxItem Content="Custom" />
                                    <ComboBoxItem Content="Default" />
                                    <ComboBoxItem Content="Hand" />
                                    <ComboBoxItem Content="High Accuracy" />
                                    <ComboBoxItem Content="High Density" />
                                    <ComboBoxItem Content="Medium Density" />
                                </ComboBox>
                            </Grid> 

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Resolution:" Foreground="#B0BCC7" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" Width="120" Height="25" Background="White" SelectedValuePath="Content" SelectedValue="{Binding CameraSettings.SelectedResolution, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="256 x 144"/>
                                    <ComboBoxItem Content="424 x 240"/>
                                    <ComboBoxItem Content="480 x 270"/>
                                    <ComboBoxItem Content="640 x 360"/>
                                    <ComboBoxItem Content="640 x 480"/>
                                    <ComboBoxItem Content="848 x 480"/>
                                    <ComboBoxItem Content="1280 x 720"/>
                                    <ComboBoxItem Content="1288 x 808"/>
                                </ComboBox>
                            </Grid> 

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Frame Rate (FPS):" Foreground="#B0BCC7" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" Width="60" Height="25" Background="White" SelectedValuePath="Content" SelectedValue="{Binding CameraSettings.SelectedFPS,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="5" />
                                    <ComboBoxItem Content="15" />
                                    <ComboBoxItem Content="25" />
                                    <ComboBoxItem Content="30" />
                                    <ComboBoxItem Content="60" />
                                    <ComboBoxItem Content="90" />
                                </ComboBox>
                            </Grid> 

                            <TextBlock Text="Available Streams:" Foreground="#AAA" Margin="0,0,0,5"/> <!--Available Streams-->
                            <Grid Margin="5,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding CameraSettings.IsDepthEnabled}" Content="Depth" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" Width="70" Height="25" HorizontalAlignment="Left" Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                          SelectedValuePath="Content" SelectedValue="{Binding CameraSettings.SelectedDepthFormat}">
                                    <ComboBoxItem Content="Z16" />
                                </ComboBox>

                                <CheckBox Grid.Row="1" Grid.Column="0" Content="Infrared 1" IsChecked="{Binding CameraSettings.Infrared1Enabled}" Foreground="White" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="2" Grid.Column="0" Content="Infrared 2" IsChecked="{Binding CameraSettings.Infrared2Enabled}" Foreground="White" VerticalAlignment="Center"/>

                                <CheckBox Grid.Row="3" Grid.Column="0" IsChecked="{Binding CameraSettings.IsColorEnabled}" Content="Color" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" Width="70" Height="25" HorizontalAlignment="Left" Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                          SelectedValuePath="Content" SelectedValue="{Binding CameraSettings.SelectedColorFormat}">
                                    <ComboBoxItem Content="RGB8" />
                                    <ComboBoxItem Content="YUYV" />
                                    <ComboBoxItem Content="BGR8" />
                                    <ComboBoxItem Content="RGBA8" />
                                    <ComboBoxItem Content="BGRA8" />
                                </ComboBox>

                                <CheckBox Grid.Row="4" Grid.Column="0" Content="Enable Auto Exposure" IsChecked="{Binding CameraSettings.AutoExposureEnabled}" Foreground="White" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="ASIC Temperature:" Foreground="White" VerticalAlignment="Center" Margin="10 0 0 0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtAsicTemp" Text="{Binding CameraSettings.AsicTemperature}" Foreground="#FFB000" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    <TextBlock Text=" °C" Foreground="#FFB000" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid> 

                            <Separator Background="#333" Margin="0,0"/>
                            <Expander Header="Controls" Background="#474F5A" Foreground="White" FontWeight="Bold" IsExpanded="False" Margin="0,5,0,0">
                                <StackPanel Margin="15,10,0,0">
                                    <TextBlock Text="Exposure:" Foreground="#AAA" FontSize="11"/>
                                    <Grid Margin="0,5,0,10">
                                        <Slider x:Name="ExposureSlider" Minimum="1" Maximum="165000" Value="{Binding CameraSettings.Exposure}" VerticalAlignment="Center" IsEnabled="{Binding CameraSettings.AutoExposureEnabled, Converter={StaticResource InverseBooleanConverter}}"/>
                                        <TextBlock Text="{Binding Value, ElementName=ExposureSlider, StringFormat={}{0:N0}}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    </Grid>
                                    

                                    <TextBlock Text="Gain:" Foreground="#AAA" FontSize="11"/>
                                    <Grid Margin="0,5,0,10">
                                        <Slider x:Name="GainSlider" Minimum="16" Maximum="248" Value="{Binding CameraSettings.Gain}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value, ElementName=GainSlider, StringFormat={}{0:N0}}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Power Line Frequency:" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Height="25" Background="White" Foreground="Black" BorderBrush="#3F3F46" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="Auto" IsSelected="True"/>
                                            <ComboBoxItem Content="50Hz"/>
                                            <ComboBoxItem Content="60Hz"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,5,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Error Polling Enabled:" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"  Height="25" Background="White" Foreground="Black" BorderBrush="#3F3F46" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="Enabled" IsSelected="True"/>
                                            <ComboBoxItem Content="Disabled"/>
                                        </ComboBox>
                                    </Grid>

                                    <CheckBox Content="Output Trigger Enabled" Foreground="#AAA" FontSize="11" Margin="0,5"/>

                                    <TextBlock Text="Depth Units:" Foreground="#AAA" FontSize="11" Margin="0,10,0,0"/>
                                    <Grid Margin="0,5,0,10">
                                        <Slider x:Name="DepthUnitSlider" Minimum="0.0001" Maximum="1" Value="0.0001" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value, ElementName=DepthUnitSlider, StringFormat={}{0:N0}}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Separator Background="#333"/>
                            <Expander Header="Depth Visualization" Background="#474F5A" Foreground="White" FontWeight="Bold" IsExpanded="False" Margin="0,5,0,0">
                                <StackPanel Margin="10,10,10,10">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Visual Preset:" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Height="25" Background="White" Foreground="Black" BorderBrush="#3F3F46" SelectedValue="{Binding VisualPreset}" 
                                                  HorizontalContentAlignment="Left" VerticalAlignment="Center">
                                            <ComboBoxItem Content="Dynamic" IsSelected="True"/>
                                            <ComboBoxItem Content="Fixed"/>
                                            <ComboBoxItem Content="Near"/>
                                            <ComboBoxItem Content="Far"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Color Scheme:" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Height="25" Background="White" Foreground="Black" BorderBrush="#3F3F46" SelectedValue="{Binding SelectedColormap}" 
                                                  HorizontalContentAlignment="Left" VerticalAlignment="Center">
                                            <ComboBoxItem Content="Jet" IsSelected="True"/>
                                            <ComboBoxItem Content="Classic"/>
                                            <ComboBoxItem Content="White to Black"/>
                                            <ComboBoxItem Content="Bio"/>
                                            <ComboBoxItem Content="Cold"/>
                                            <ComboBoxItem Content="Warm"/>
                                            <ComboBoxItem Content="Quantized"/>
                                            <ComboBoxItem Content="Pattern"/>
                                            <ComboBoxItem Content="Hue"/>
                                        </ComboBox>
                                    </Grid>

                                    <CheckBox x:Name="cbDecimation" Content="Decimation Filter" IsChecked="{Binding CameraSettings.IsDecimationFilterEnabled}" Foreground="#AAA" Margin="0,2,0,5"/>
                                    <CheckBox x:Name="cbSpatial" Content="Spatial Filter" IsChecked="{Binding CameraSettings.IsSpatialFilterEnabled}" Foreground="#AAA" Margin="0,2,0,5"/>
                                    <CheckBox x:Name="cbTemporal" Content="Temporal Filter" IsChecked="{Binding CameraSettings.IsTemporalFilterEnabled}" Foreground="#AAA" Margin="0,2,0,5"/>
                                    <CheckBox x:Name="cbHoleFilling" Content="Hole Filling Filter" IsChecked="{Binding CameraSettings.IsHoleFillingFilterEnabled}" Foreground="#AAA" Margin="0,2,0,5"/>
                                    <CheckBox x:Name="cbAlign" Content="Align Depth to Color" IsChecked="{Binding CameraSettings.IsAlignEnabled}" Foreground="#46A3FF" FontWeight="Bold" Margin="0,5,0,5"/>

                                    <TextBlock Text="Min Distance (m)" Foreground="#AAA" FontSize="11"/>
                                    <Grid Margin="0,5,0,10">
                                        <Slider x:Name="MinDistanceSlider" Minimum="0.1" Maximum="2" Value="{Binding CameraSettings.MinDistance}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value, ElementName=MinDistanceSlider, StringFormat={}{0:F2}}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    </Grid>

                                    <TextBlock Text="Max Distance (m)" Foreground="#AAA" FontSize="11"/>
                                    <Grid Margin="0,5,0,10">
                                        <Slider x:Name="MaxDistanceSlider" Minimum="1" Maximum="15" Value="{Binding CameraSettings.MaxDistance}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value, ElementName=MaxDistanceSlider, StringFormat={}{0:F1}}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <Button Content="FACTORY RESET CAMERA" 
                                    Command="{Binding FactoryResetCommand}"
                                    Background="#FF4B4B" Foreground="White" 
                                    FontWeight="Bold" Height="30" Margin="10,20,10,10">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border> 

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="6*"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#000" CornerRadius="5" Margin="5" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <Border Height="28" VerticalAlignment="Top" Background="#AA1E2129" Panel.ZIndex="3">
                                <Grid>
                                    <TextBlock Foreground="#FF8E2D" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="10,0" HorizontalAlignment="Left">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Depth Stream (2D)"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Is3DMode}" Value="True">
                                                        <Setter Property="Text" Value="Depth Sensing (3D View)"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,2,0">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Toggle Recording (.bag)" Width="26" Height="26" Command="{Binding RecordCommand}">
                                            <materialDesign:PackIcon Width="16" Height="16">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="Record"/>
                                                        <Setter Property="Foreground" Value="#AAA"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CameraSettings.IsRecording}" Value="True">
                                                                <Setter Property="Kind" Value="Stop"/>
                                                                <Setter Property="Foreground" Value="#FF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Take Snapshot" Width="26" Height="26" Foreground="#AAA" Command="{Binding SnapshotCommand}">
                                            <materialDesign:PackIcon Kind="Camera" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Pause Stream" Width="26" Height="26" Foreground="#AAA">
                                            <materialDesign:PackIcon Kind="Pause" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Information" Width="26" Height="26" Foreground="#AAA">
                                            <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Settings" Width="26" Height="26" Foreground="#AAA">
                                            <materialDesign:PackIcon Kind="Settings" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Close" Width="26" Height="26" Foreground="#FF4444">
                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="5,30,5,5">
                                <Grid Visibility="{Binding Is3DMode, Converter={StaticResource InverseBooleanConverter}, ConverterParameter=Visibility}">
                                    <Image Name="imgDepth" Source="{Binding DepthSource}" Stretch="Uniform" MouseMove="Img_MouseMove" IsHitTestVisible="True"/>

                                    <Canvas Panel.ZIndex="10" IsHitTestVisible="False">
                                        <Border Background="#AA000000" Padding="8,5" CornerRadius="4" Canvas.Left="{Binding TooltipX}" Canvas.Top="{Binding TooltipY}" Visibility="{Binding IsTooltipVisible}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding MousePosText}" Foreground="#46A3FF" FontSize="10" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding DistanceText}" Foreground="#00FF00" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Canvas>

                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,15,20" Width="45" Height="220">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" BorderBrush="#FFF" BorderThickness="0.5">
                                            <Rectangle Fill="{Binding DepthGradientSource}" />
                                        </Border>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DepthScaleLabels}" Margin="5,0,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="9" VerticalAlignment="Top" TextAlignment="Left"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>

                                <Grid x:Name="PointCloudContainer" Background="#0A0A0A" Visibility="{Binding Is3DViewVisible}">
                                    <helix:HelixViewport3D x:Name="viewport" ZoomExtentsWhenLoaded="True" ShowCoordinateSystem="True">
                                        <helix:SunLight/>
                                        <helix:PointsVisual3D Points="{Binding PointCloudPoints}" Color="Lime" Size="2"/>
                                    </helix:HelixViewport3D>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#000" CornerRadius="5" Margin="5" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <Border Height="28" VerticalAlignment="Top" Background="#AA1E2129" Panel.ZIndex="1">
                                <Grid>
                                    <TextBlock Text="Color Stream" Foreground="#46A3FF" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,2,0">

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Toggle Recording (.bag)" Width="26" Height="26" Command="{Binding RecordCommand}">
                                            <materialDesign:PackIcon Width="16" Height="16">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="Record"/>
                                                        <Setter Property="Foreground" Value="#AAA"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CameraSettings.IsRecording}" Value="True">
                                                                <Setter Property="Kind" Value="Stop"/>
                                                                <Setter Property="Foreground" Value="#FF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Button>
                                        
                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Take Snapshot" Width="26" Height="26" Foreground="#AAA" Command="{Binding SnapshotCommand}">
                                            <materialDesign:PackIcon Kind="Camera" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Pause Stream" Width="26" Height="26" Foreground="#AAA">
                                            <materialDesign:PackIcon Kind="Pause" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Information" Width="26" Height="26" Foreground="#AAA">
                                            <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Settings" Width="26" Height="26" Foreground="#AAA">
                                            <materialDesign:PackIcon Kind="Settings" Width="16" Height="16"/>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Close"  Width="26" Height="26" Foreground="#FF4444">
                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Image Name="imgColor" Source="{Binding ColorSource}" Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality" Margin="5,30,5,5"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#0C0C0C" CornerRadius="5" Margin="5" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Margin="12,5,12,0" VerticalAlignment="Top">
                                <TextBlock Text="LOG" Foreground="#00FF00" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                    <Path Data="M12,2C6.47,2 2,6.47 2,12C2,17.53 6.47,22 12,22C17.53,22 22,17.53 22,12C22,6.47 17.53,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z" 
                                          Fill="#FF4545" Width="12" Height="12" Stretch="Fill" Margin="5,0,2,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ErrorCount}" Foreground="#AAA" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" 
                                          Fill="#FFD645" Width="12" Height="12" Stretch="Fill" Margin="5,0,2,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding WarningCount}" Foreground="#AAA" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <Path Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z" 
                                          Fill="#45FF5F" Width="12" Height="12" Stretch="Fill" Margin="5,0,2,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SuccessCount}" Foreground="#AAA" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Button Command="{Binding ClearLogCommand}" Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                              Fill="Yellow" Width="12" Height="12" Stretch="Fill" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                        <TextBlock Text="Clear" Foreground="Red" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.7"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,34,0,5">
                                <ItemsControl ItemsSource="{Binding LogEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5,2">
                                                <TextBlock Text="{Binding Time}" Foreground="Gray" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Message}" Margin="5,0,0,0" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Success">
                                                                    <Setter Property="Foreground" Value="#45FF5F"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Error">
                                                                    <Setter Property="Foreground" Value="#FF4545"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="#FFD645"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border> 

                    <Border Grid.Column="1" Background="#1E2129" CornerRadius="5" Margin="5" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="Frame Drops per Second" Foreground="#AAA" FontSize="10" Margin="5" VerticalAlignment="Top"/>
                            <lvc:CartesianChart Margin="5 20 5 5" Series="{Binding FrameDropUpdate}" AnimationsSpeed="0:0:0.1" Hoverable="False">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Viewer Processing Rate" Foreground="#888" MinValue="0" MaxValue="100">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#22FFFFFF" Step="11.11" IsEnabled="True"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>

                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis MinValue="0" MaxValue="6" Foreground="#888">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#22FFFFFF" StrokeDashArray="2" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border> 
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>