<prism:PrismApplication x:Class="RobotTesting.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RobotTesting"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:WinStyles.Converter;assembly=WinStyles"
             xmlns:prism="http://prismlibrary.com/"> 
    <prism:PrismApplication.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light"
                                 PrimaryColor="Blue"
                                 SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                <ResourceDictionary Source="/WinStyles;component/UIStyles/DataGridCustomStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:TileTypeToColorConverter x:Key="TileTypeToColorConverter"/>
            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="DeepSkyBlue" />
        </ResourceDictionary>
    </prism:PrismApplication.Resources>
</prism:PrismApplication>
