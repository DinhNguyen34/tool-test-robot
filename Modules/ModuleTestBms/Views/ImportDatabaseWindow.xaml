<Window x:Class="ModuleTestBms.Views.ImportDatabaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Import CAN Database" Height="380" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Import CAN Database (CSV → JSON)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- CSV file selection -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CSV File:" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="TxtCsvPath" IsReadOnly="True" FontSize="13" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse..." Margin="8,0,0,0" Click="BtnBrowse_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}" Padding="12,4"/>
        </Grid>

        <!-- Expected format hint -->
        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,0,0,12"
                   Text="Expected CSV header: Message Name, ID (Hex), ID (Dec), DLC (Bytes), Tx Node, Format, Signal Name, Start Bit, Length (Bits), Byte Order, Data Type, Factor, Offset, Min, Max, Unit, Rx Node, Description &amp; Values"/>

        <!-- Log output -->
        <TextBox Grid.Row="3" x:Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="11"
                 BorderThickness="1" Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Import &amp; Convert" x:Name="BtnImport" Click="BtnImport_Click"
                    Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="Close" Click="BtnClose_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
