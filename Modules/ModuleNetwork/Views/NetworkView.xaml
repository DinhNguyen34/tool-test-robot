<UserControl x:Class="ModuleNetwork.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#339AF0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#FA5252"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#555"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- config row -->
            <RowDefinition Height="Auto"/>   <!-- send row -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
            <RowDefinition Height="*"/>      <!-- log -->
        </Grid.RowDefinitions>
        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resource;component/Images/Robot-32.png" Height="24" Width="24" Margin="80,0,8,0"/>
                    <TextBlock Text="UDP Network Test" FontSize="20" FontWeight="Bold"
                               Foreground="#339AF0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="← Back" Style="{StaticResource SecondaryBtn}"
                        Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left" Width="75"/>
            </Grid>
        </Border>

        <!-- Config row -->
        <Border Grid.Row="1" Background="#252526" Margin="0,1,0,0" Padding="12,10">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Remote IP" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding RemoteIp, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}" Width="140"/>

                <TextBlock Text="Remote Port" Style="{StaticResource LabelStyle}" Margin="16,0,8,0"/>
                <TextBox Text="{Binding RemotePort, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}" Width="70"/>

                <TextBlock Text="Local Port" Style="{StaticResource LabelStyle}" Margin="16,0,8,0"/>
                <TextBox Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}" Width="70"/>

                <Button Content="{Binding ListenButtonLabel}"
                        
                        
                        Command="{Binding ToggleListenCommand}"
                        Margin="16,0,0,0" Width="110">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsListening}" Value="True">
                                    <Setter Property="Background" Value="#FA5252"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- Send row -->
        <Border Grid.Row="2" Background="#252526" Margin="0,1,0,0" Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Message" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding SendMessage, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}" Width="450">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Send" Command="{Binding SendCommand}"
                        Style="{StaticResource PrimaryBtn}" Margin="10,0,0,0" Width="80"/>
                <Button Content="Clear Log" Command="{Binding ClearLogCommand}"
                        Style="{StaticResource SecondaryBtn}" Margin="8,0,0,0" Width="80"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#1A3A5A" Padding="12,4">
            <TextBlock Text="{Binding StatusText}" Foreground="#339AF0" FontSize="12"/>
        </Border>

        <!-- Log panel -->
        <DataGrid x:Name="LogDataGrid"
                  Grid.Row="4"
                  ItemsSource="{Binding LogEntries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  RowBackground="#1E1E1E"
                  AlternatingRowBackground="#222222"
                  Foreground="White"
                  Background="#1E1E1E"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  FontFamily="Consolas"
                  FontSize="12"
                  Margin="0,1,0,0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#252526"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,3"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Direction}" Value="RX">
                            <Setter Property="Foreground" Value="#69DB7C"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Direction}" Value="TX">
                            <Setter Property="Foreground" Value="#74C0FC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Direction}" Value="ERR">
                            <Setter Property="Foreground" Value="#FF6B6B"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Direction}" Value="INFO">
                            <Setter Property="Foreground" Value="#FFD43B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"      Binding="{Binding Timestamp}" Width="100"/>
                <DataGridTextColumn Header="Dir"       Binding="{Binding Direction}"  Width="45"/>
                <DataGridTextColumn Header="Source"    Binding="{Binding Source}"     Width="160"/>
                <DataGridTextColumn Header="Message"   Binding="{Binding Message}"    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
