<Window x:Class="ModuleTestLed.Views.TestOneLedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Test One LED" Height="650" Width="920"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- Left: LED selection by port -->
        <materialDesign:Card Grid.Column="0" Padding="8" Margin="0,0,8,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="LED Selection" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="Select All" Click="SelectAll_Click" Margin="16,0,4,0"
                            Style="{StaticResource MaterialDesignFlatButton}" FontSize="12"/>
                    <Button Content="Deselect All" Click="DeselectAll_Click"
                            Style="{StaticResource MaterialDesignFlatButton}" FontSize="12"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PortGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="4,6">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding PortName}" FontWeight="Bold" FontSize="14"
                                                       VerticalAlignment="Center" Width="60"/>
                                            <CheckBox Content="All" IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                                                      Margin="8,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Leds}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              Content="{Binding DisplayName}"
                                                              Margin="2,1" MinWidth="44" FontSize="12"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </materialDesign:Card>

        <!-- Right: RGBW sliders + Send -->
        <materialDesign:Card Grid.Column="1" Padding="12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="RGBW Control" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <!-- R -->
                <TextBlock Text="R (Red)" Foreground="Red" FontWeight="SemiBold"/>
                <Slider x:Name="SliderR" Minimum="0" Maximum="255" Value="255"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        Foreground="Red" Margin="0,4,0,2"/>
                <TextBlock Text="{Binding Value, ElementName=SliderR, StringFormat={}{0:0}}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- G -->
                <TextBlock Text="G (Green)" Foreground="Green" FontWeight="SemiBold"/>
                <Slider x:Name="SliderG" Minimum="0" Maximum="255" Value="255"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        Foreground="Green" Margin="0,4,0,2"/>
                <TextBlock Text="{Binding Value, ElementName=SliderG, StringFormat={}{0:0}}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- B -->
                <TextBlock Text="B (Blue)" Foreground="DodgerBlue" FontWeight="SemiBold"/>
                <Slider x:Name="SliderB" Minimum="0" Maximum="255" Value="255"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        Foreground="DodgerBlue" Margin="0,4,0,2"/>
                <TextBlock Text="{Binding Value, ElementName=SliderB, StringFormat={}{0:0}}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- W -->
                <TextBlock Text="W (White)" Foreground="Gray" FontWeight="SemiBold"/>
                <Slider x:Name="SliderW" Minimum="0" Maximum="255" Value="255"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        Foreground="Gray" Margin="0,4,0,2"/>
                <TextBlock Text="{Binding Value, ElementName=SliderW, StringFormat={}{0:0}}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Send button -->
                <Button Content="Send CMD" Click="SendCmd_Click" Height="40" FontSize="16"
                        Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Padding="16,6"/>

                <!-- Status -->
                <TextBlock x:Name="TxtStatus" TextWrapping="Wrap" Margin="0,12,0,0"
                           FontSize="12" HorizontalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
