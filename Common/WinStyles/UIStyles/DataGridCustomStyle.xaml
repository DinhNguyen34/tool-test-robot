<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <!-- RowStyle -->


    
    <Style TargetType="DataGridRow" x:Key="CustomGridRow">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MaxHeight" Value="200" />
        <Style.Triggers>
            <!-- Các trigger cho DataGridRow nếu cần -->
        </Style.Triggers>
    </Style>
    
    <Style TargetType="DataGridRow" x:Key="CustomGridRow2">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MaxHeight" Value="200" />
        <Style.Triggers>
            <!-- Các trigger cho DataGridRow nếu cần -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell" x:Key="CustomGridCell2">
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Column.DisplayIndex}" Value="0">
                <Setter Property="BorderThickness" Value="1,0,1,1"/>
            </DataTrigger>
            <!-- Các trigger cho DataGridRow nếu cần -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ColumnHeaderStyle -->
    <Style TargetType="DataGridColumnHeader" x:Key="CustomGridHeader" >
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="0,1,1,1" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="MinHeight" Value="30" />
        <Style.Triggers>
            <!-- Custom Header Đầu -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=DisplayIndex}" Value="0">
                <Setter Property="BorderThickness" Value="1,1,1,1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <Style TargetType="DataGridColumnHeader" x:Key="CustomGridHeader2">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="0,1,1,1" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="Background" Value="LightBlue"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="MinHeight" Value="30" />
        <Style.Triggers>
            <!-- Custom Header Đầu -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=DisplayIndex}" Value="0">
                <Setter Property="BorderThickness" Value="1,1,1,1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!-- CellStyle -->
    <Style TargetType="DataGridCell" x:Key="CustomGridCell">
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Style.Triggers>
            <!-- Cell đầu tiên -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Column.DisplayIndex}" Value="0">
                <Setter Property="BorderThickness" Value="1,0,1,1"/>
            </DataTrigger>
            <!-- Khi Cell được chọn -->
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Black" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <Style TargetType="DataGridCell" x:Key="DTCCellStyle">
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Name}" Value="This ECU doesn't have any DTC">
                <Setter Property="Background" Value="LightGreen"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Name}" Value="This ECU doesn't response">
                <Setter Property="Background" Value="LightPink"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Column.DisplayIndex}" Value="0">
                <Setter Property="BorderThickness" Value="1,0,1,1"/>
            </DataTrigger>
            <!-- Khi Cell được chọn -->
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter Property="BorderBrush" Value="Black" />
                <Setter Property="Background" Value="LightBlue" />
                <Setter Property="Foreground" Value="Black" />
            </DataTrigger>
        </Style.Triggers>
    </Style>


    <Style TargetType="DataGrid" x:Key="BasicDataGrid">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="FrozenColumnCount" Value="0" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="CanUserResizeColumns" Value="False" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="CanUserSortColumns" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="False" />
        <Setter Property="AlternationCount" Value="1000" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="White" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style TargetType="TextBlock" x:Key="TextCenter">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Padding" Value="5,2" />
    </Style>
    <Style TargetType="TextBlock" x:Key="FlashStatus">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Padding" Value="5,2" />
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="Blue"/>
        <Style.Triggers>
            <Trigger Property="Text" Value="FAIL">
                <Setter Property="Foreground" Value="Red"/>
            </Trigger>
            <Trigger Property="Text" Value="DONE">
                <Setter Property="Foreground" Value="Green"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="TextBlock" x:Key="TextLeft">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Padding" Value="5,2" />
    </Style>
    <Style TargetType="CheckBox" x:Key="CheckCenter">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="3" />
    </Style>
    
</ResourceDictionary>